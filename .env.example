# CyberGuard Next.js + Supabase Environment Variables Example

# Supabase Public Keys (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase Service Role Secret Key (NEVER expose client-side, keep safe in server context)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Site URL for redirection configurations
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
